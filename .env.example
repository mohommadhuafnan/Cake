# Firebase Auth — Google + Email (Firebase Console → Project settings → Your apps → Web)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=cake-90105.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=cake-90105
VITE_FIREBASE_STORAGE_BUCKET=cake-90105.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=85063282626
VITE_FIREBASE_APP_ID=your_app_id

# Database (Supabase PostgreSQL — server-side only, never expose in VITE_*)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.fipsclbgsrjldhtdaumj.supabase.co:5432/postgres
SUPABASE_SECRET_KEY=your_secret_key
SUPABASE_JWKS_URL=https://fipsclbgsrjldhtdaumj.supabase.co/auth/v1/.well-known/jwks.json

# Supabase — frontend (Vite uses VITE_ prefix; baked in at build time)
VITE_SUPABASE_URL=https://fipsclbgsrjldhtdaumj.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Legacy PHP backend (optional if still using cPanel API)
VITE_API_URL=/backend/api
VITE_SITE_URL=https://cake-jade-two.vercel.app

# ── Vercel: set all vars in Dashboard → Settings → Environment Variables
# Run backend/migrations/supabase.sql in Supabase SQL Editor first.
